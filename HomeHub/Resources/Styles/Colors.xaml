<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--  Brand  -->
    <Color x:Key="Primary">#3B82F6</Color>
    <Color x:Key="PrimaryDark">#2563EB</Color>
    <Color x:Key="PrimaryLight">#DBEAFE</Color>

    <!--  Neutrals  -->
    <Color x:Key="Secondary">#1E293B</Color>
    <Color x:Key="SecondaryDark">#0F172A</Color>

    <!--  Grays  -->
    <Color x:Key="Gray100">#F1F5F9</Color>
    <Color x:Key="Gray200">#E2E8F0</Color>
    <Color x:Key="Gray300">#CBD5E1</Color>
    <Color x:Key="Gray400">#94A3B8</Color>
    <Color x:Key="Gray500">#64748B</Color>
    <Color x:Key="Gray600">#475569</Color>
    <Color x:Key="Gray900">#0F172A</Color>

    <!--  Surfaces  -->
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="PageBackground">#F1F5F9</Color>

    <!--  Status  -->
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Danger">#EF4444</Color>

    <!--  White / Black  -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

</ResourceDictionary>
