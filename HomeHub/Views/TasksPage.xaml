<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:HomeHub.ViewModels"
    xmlns:models="clr-namespace:HomeHub.Models"
    x:Class="HomeHub.Views.TasksPage"
    x:DataType="vm:TasksViewModel"
    Title="Tasks"
    BackgroundColor="{StaticResource PageBackground}">

    <CollectionView
        ItemsSource="{Binding Tasks}"
        Margin="0,8,0,0">

        <CollectionView.Header>
            <Label
                Text="Household Tasks"
                FontSize="20"
                FontAttributes="Bold"
                TextColor="{StaticResource Secondary}"
                Margin="20,16,20,4" />
        </CollectionView.Header>

        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:HouseholdTask">
                <Border Style="{StaticResource CardBorderStyle}" Margin="20,4">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label
                                Text="{Binding Title}"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="{StaticResource Secondary}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsDone}" Value="True">
                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                        <Setter Property="TextColor" Value="{StaticResource Gray400}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Label
                                Text="{Binding DueDate, StringFormat='Due: {0:MMM dd, yyyy}'}"
                                FontSize="12"
                                TextColor="{StaticResource Gray500}" />
                        </VerticalStackLayout>

                        <CheckBox
                            Grid.Column="1"
                            IsChecked="{Binding IsDone}"
                            Color="{StaticResource Primary}"
                            VerticalOptions="Center" />

                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.EmptyView>
            <Label
                Text="No tasks found."
                FontSize="16"
                TextColor="{StaticResource Gray400}"
                HorizontalOptions="Center"
                Margin="0,40,0,0" />
        </CollectionView.EmptyView>

    </CollectionView>

</ContentPage>
