<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:HomeHub.ViewModels"
    xmlns:models="clr-namespace:HomeHub.Models"
    x:Class="HomeHub.Views.BillsPage"
    x:DataType="vm:BillsViewModel"
    Title="Bills"
    BackgroundColor="{StaticResource PageBackground}">

    <CollectionView
        ItemsSource="{Binding Bills}"
        Margin="0,8,0,0">

        <CollectionView.Header>
            <Label
                Text="Monthly Bills"
                FontSize="20"
                FontAttributes="Bold"
                TextColor="{StaticResource Secondary}"
                Margin="20,16,20,4" />
        </CollectionView.Header>

        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:Bill">
                <Border Style="{StaticResource CardBorderStyle}" Margin="20,4">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="12" RowSpacing="6">

                        <!-- Bill name -->
                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="{Binding Name}"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="{StaticResource Secondary}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsPaid}" Value="True">
                                    <Setter Property="TextDecorations" Value="Strikethrough" />
                                    <Setter Property="TextColor" Value="{StaticResource Gray400}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>

                        <!-- Paid toggle -->
                        <CheckBox
                            Grid.Row="0"
                            Grid.Column="1"
                            Grid.RowSpan="2"
                            IsChecked="{Binding IsPaid}"
                            Color="{StaticResource Primary}"
                            VerticalOptions="Center" />

                        <!-- Amount and due date -->
                        <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="12">
                            <Label
                                Text="{Binding Amount, StringFormat='${0:F2}'}"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="{StaticResource Primary}" />
                            <Label
                                Text="{Binding DueDate, StringFormat='Due: {0:MMM dd}'}"
                                FontSize="12"
                                TextColor="{StaticResource Gray500}" />
                        </HorizontalStackLayout>

                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.EmptyView>
            <Label
                Text="No bills found."
                FontSize="16"
                TextColor="{StaticResource Gray400}"
                HorizontalOptions="Center"
                Margin="0,40,0,0" />
        </CollectionView.EmptyView>

    </CollectionView>

</ContentPage>
